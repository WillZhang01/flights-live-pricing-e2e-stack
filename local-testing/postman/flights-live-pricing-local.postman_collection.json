            "description": "Creates a round-trip flight search session with two legs:\n- Leg 1: `{{origin}}` → `{{destination}}` on `{{outbound_date}}`\n- Leg 2: `{{destination}}` → `{{origin}}` on `{{return_date}}`\n\nThe `session_id` is automatically saved for the Poll request."
          }
        },
        {
          "name": "2. Poll Search",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has itineraries', () => {",
                  "    pm.expect(res.itineraries).to.be.an('array').with.length.above(0);",
                  "});",
                  "",
                  "const agents = res.agents || [];",
                  "const pending = agents.filter(a => a.update_status === 'pending').length;",
                  "const complete = agents.length - pending;",
                  "",
                  "console.log('agents: ' + complete + '/' + agents.length + ' complete');",
                  "console.log('itineraries: ' + (res.itineraries || []).length);",
                  "",
                  "if (pending === 0 && agents.length > 0) {",
                  "    console.log('✓ All agents complete — no need to poll again');",
                  "} else {",
                  "    console.log('⏳ ' + pending + ' agent(s) still pending — poll again');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Skyscanner-ChannelId", "value": "{{channel_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/fps3/search/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "fps3", "search", "{{session_id}}"]
            },
            "description": "Polls for live pricing updates for the round-trip session created by **Create Search**.\n\nKeep polling until the Console shows `✓ All agents complete`. Must be done within 60 seconds of the Create request."
          }
        }
      ]
    },
